top_sort(V, Order) :-
    findall(E, edge(V, E), Edges),
    (Edges = [] -> Order = [V] ;  % Caso base: vértice sin aristas
     findall(N, top_sort(N, TempOrder), TempOrders),
     append(TempOrders, [V], Order)).

