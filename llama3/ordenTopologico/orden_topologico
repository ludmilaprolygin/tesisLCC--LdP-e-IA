top_sort(V, Order) :-
    \+findedge(V),  % Caso base: vértice sin aristas
    (findall(E, edge(V, E), _Edges) ->  % Si hay aristas, ordena los vecinos
     findall(N, top_sort(N, TempOrder), TempOrders),
     append(TempOrders, [V], Order) ;  % Sino, el vértice no tiene aristas ni vecinos
    Order = [V]).

