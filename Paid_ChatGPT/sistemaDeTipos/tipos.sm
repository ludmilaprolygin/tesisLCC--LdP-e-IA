| precios suma cantidad promedio umbral |

precios := #(10 20 30 40 50).
umbral := 25.

suma := 0.
cantidad := 0.

precios do: [:precio |
    precio > umbral ifTrue: [
        suma := suma + precio.
        cantidad := cantidad + 1
    ].
].

promedio := (cantidad = 0)
    ifTrue: [0]
    ifFalse: [suma / cantidad].

Transcript show: promedio printString; cr.