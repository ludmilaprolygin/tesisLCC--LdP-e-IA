% Definimos la relación para calcular el precio final
precio_final(PrecioOriginal, DescuentoPorcentaje, PrecioFinal) :-
    % Convertimos el porcentaje de descuento a número real
    string_number(DescuentoPorcentaje, Porcentaje),
    % Calculamos el descuento en dólares (PrecioOriginal * Porcentaje / 100)
    Descuento is PrecioOriginal * Porcentaje / 100,
    % Restamos el descuento del precio original para obtener el precio final
    PrecioFinal is PrecioOriginal - Descuento.

% Llamada a la función con el precio original y el descuento como cadenas
calcular_precio_final :-
    PrecioOriginal = "50",
    DescuentoPorcentaje = "10",
    % Convertimos las cadenas a números reales para realizar los cálculos
    string_number(PrecioOriginal, NumPrecioOriginal),
    string_number(DescuentoPorcentaje, NumDescuentoPorcentaje),
    % Llamamos a la relación precio_final con los números
    precio_final(NumPrecioOriginal, NumDescuentoPorcentaje, PrecioFinal),
    % Imprimimos el resultado
    writeln('El precio final es: ').